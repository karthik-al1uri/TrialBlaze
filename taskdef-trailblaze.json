{
  "family": "trailblaze-backend",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::817685572742:role/ecsTaskExecutionRole",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "trailblaze-backend",
      "image": "817685572742.dkr.ecr.us-east-2.amazonaws.com/trailblaze-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "MONGO_DB_NAME",
          "value": "trailblaze"
        }
      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:817685572742:secret:trailblaze/mongo-uri"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trailblaze-backend",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}