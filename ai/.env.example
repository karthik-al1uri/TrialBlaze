# TrailBlaze AI — Environment Variables
# Copy this file to ai/.env and fill in your values
# NEVER commit ai/.env to git

# ── Required ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trailblaze
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=
NPS_API_KEY=
ORS_API_KEY=

# ── Model Config ──────────────────────────────────────────
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
